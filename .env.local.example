# Copy this file to .env.local and fill in your own values.

# OpenAI API key, used by /api/update-landscape
OPENAI_API_KEY=sk-your-openai-key

# Secret token used by your cron job to access /api/update-landscape
CRON_SECRET=some-long-random-secret

# Google AdSense client ID (optional, only needed if you enable ads)
# Example: ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-your-adsense-client-id
